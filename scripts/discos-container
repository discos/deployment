#!/usr/bin/env python3
"""Some command line examples:

  $ discos-container build
  $ discos-container load discos_manager.tar
  $ discos-container create
  $ discos-container start
  $ discos-container stop
  $ discos-container restart
  $ discos-container status
  $ discos-container destroy
  $ discos-container save discos_manager.tar
  $ discos-container remove
"""

import argparse
import os
import subprocess
import sys
import getpass
from pathlib import Path

import deployment

CONTAINER = "manager"
IMAGE = "discos-centos-7.9"
BASE_IMAGE = IMAGE + ":base"
LATEST_IMAGE = IMAGE + ":latest"
GHCR_ORG = "ghcr.io/discos"
NETWORK = "discos_net"
SUBNET = "192.168.56.0/24"
DEFAULT_INVENTORY = "development"


def _machine_ip(inventory=DEFAULT_INVENTORY):
    return deployment.getIp(CONTAINER, inventory)


def _check_output(cmd, **kwargs):
    return subprocess.check_output(
        cmd,
        stderr=deployment.STDERR,
        **kwargs,
    ).decode().strip()


def _docker_available():
    try:
        _check_output(["docker", "version", "--format", "{{.Server.Version}}"])
        return True
    except (subprocess.CalledProcessError, FileNotFoundError, OSError):
        return False


def _ensure_docker_available():
    if not _docker_available():
        deployment.error("Docker is not available or the daemon is not reachable!")


def _resolve_image_from_tag(tag=None):
    if tag is None:
        if deployment.dockerImageExists(LATEST_IMAGE):
            return LATEST_IMAGE
        return BASE_IMAGE

    if ":" in tag:
        return tag

    return f"{IMAGE}:{tag}"


def _resolve_ghcr_image_from_tag(tag="latest"):
    local_image = _resolve_image_from_tag(tag)
    image_name, image_tag = local_image.rsplit(":", 1)
    return f"{GHCR_ORG}/{image_name}:{image_tag}"


def build_image(image=BASE_IMAGE):
    if deployment.dockerImageExists(image):
        print(f"Image {image} already exists.")
        return 0

    return deployment.runWithProgress(
        f"Building image {image}",
        deployment.dockerBuild,
        "error while building the requested image.",
        image,
    )


def remove_image(image=LATEST_IMAGE):
    if not deployment.dockerImageExists(image):
        print(f"Image {image} not found.")
        return 1

    return deployment.runWithProgress(
        f"Removing image {image}",
        deployment._docker,
        "error while removing the requested image.",
        ["image", "rm", "-f", image],
    )


def load_image(imgfile):
    imgfile = Path(imgfile).expanduser().resolve()
    return deployment.runWithProgress(
        f"Loading image from {imgfile}",
        deployment.dockerLoadImage,
        "error while loading the requested image.",
        str(imgfile),
    )


def push_image(tag="latest"):
    local_image = _resolve_image_from_tag(tag)
    remote_image = _resolve_ghcr_image_from_tag(tag)

    if not deployment.dockerImageExists(local_image):
        print(f"Image {local_image} not found.")
        return 1

    rc = deployment.runWithProgress(
        f"Tagging image {local_image} as {remote_image}",
        deployment.dockerTagImage,
        "error while tagging the requested image.",
        local_image,
        remote_image,
    )
    if rc != 0:
        return rc

    return deployment.runWithProgress(
        f"Pushing image {remote_image}",
        deployment.dockerPushImage,
        "error while pushing the requested image.",
        remote_image,
    )


def pull_image(tag="latest"):
    local_image = _resolve_image_from_tag(tag)
    remote_image = _resolve_ghcr_image_from_tag(tag)

    rc = deployment.runWithProgress(
        f"Pulling image {remote_image}",
        deployment.dockerPullImageMaybeAuth,
        "error while pulling the requested image.",
        remote_image,
    )

    if rc == deployment.DOCKER_AUTH_REQUIRED_RC:
        if not sys.stdin.isatty():
            print("Authentication is required, but no interactive terminal is available.")
            return 1

        print(f"Authentication required to pull {remote_image}.")
        rc = login_registry()
        if rc != 0:
            return rc

        rc = deployment.runWithProgress(
            f"Pulling image {remote_image}",
            deployment.dockerPullImageMaybeAuth,
            "error while pulling the requested image.",
            remote_image,
        )
        if rc != 0:
            return rc

    elif rc != 0:
        return rc

    return deployment.runWithProgress(
        f"Tagging image {remote_image} as {local_image}",
        deployment.dockerTagImage,
        "error while tagging the pulled image locally.",
        remote_image,
        local_image,
    )


def tag_image(source_tag, target_tag):
    source_image = _resolve_image_from_tag(source_tag)
    target_image = _resolve_image_from_tag(target_tag)

    if not deployment.dockerImageExists(source_image):
        print(f"Image {source_image} not found.")
        return 1

    return deployment.runWithProgress(
        f"Tagging image {source_image} as {target_image}",
        deployment.dockerTagImage,
        "error while tagging the requested image.",
        source_image,
        target_image
    )


def status_container(inventory=DEFAULT_INVENTORY):
    print("Container:")
    print("----------")

    if not deployment.dockerContainerExists(CONTAINER):
        print(f"{CONTAINER}: not created")
    else:
        if deployment.dockerContainerRunning(CONTAINER):
            ip = _machine_ip(inventory)
            print(f"{CONTAINER}: running ({ip})")
        else:
            print(f"{CONTAINER}: stopped")

    print()
    print("Images:")
    print("-------")

    if deployment.dockerImageExists(BASE_IMAGE):
        print(f"{BASE_IMAGE}: present")
    else:
        print(f"{BASE_IMAGE}: missing")

    if deployment.dockerImageExists(LATEST_IMAGE):
        print(f"{LATEST_IMAGE}: present")
    else:
        print(f"{LATEST_IMAGE}: missing")

    return 0


def create_container(
    inventory=DEFAULT_INVENTORY,
    tag=None,
    network=NETWORK,
    subnet=SUBNET,
):
    if deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} already created.")
        return 2

    image = _resolve_image_from_tag(tag)
    if image is None:
        return 2

    ip = _machine_ip(inventory)

    rc = deployment.runWithProgress(
        f"Creating network {network}",
        deployment.dockerEnsureNetwork,
        "error while creating the requested network.",
        network,
        subnet,
    )
    if rc != 0:
        return rc

    return deployment.runWithProgress(
        f"Creating container {CONTAINER}",
        deployment.dockerEnsureContainer,
        "error while creating the requested container.",
        CONTAINER,
        ip,
        image,
        network,
    )


def start_container(inventory=DEFAULT_INVENTORY):
    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 2

    if deployment.dockerContainerRunning(CONTAINER):
        print(f"Container {CONTAINER} already running.")
        return 0

    ip = _machine_ip(inventory)
    return deployment.runWithProgress(
        f"Starting container {CONTAINER}",
        deployment.dockerStartContainer,
        "error while starting the requested container.",
        CONTAINER,
        ip,
    )


def stop_container():
    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 2

    if not deployment.dockerContainerRunning(CONTAINER):
        print(f"Container {CONTAINER} is not running.")
        return 0

    return deployment.runWithProgress(
        f"Stopping container {CONTAINER}",
        deployment.dockerStopContainer,
        "error while stopping the requested container.",
        CONTAINER,
    )


def restart_container(inventory=DEFAULT_INVENTORY):
    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 2

    ip = _machine_ip(inventory)
    return deployment.runWithProgress(
        f"Restarting container {CONTAINER}",
        deployment.dockerRestartContainer,
        "error while restarting the requested container.",
        CONTAINER,
        ip,
    )


def destroy_container(force=False):
    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 0

    if not force:
        print(f"Are you sure you want to destroy container {CONTAINER}? [y/N]: ", end="")
        choice = input().strip().lower()
        if choice not in ("y", "yes"):
            print("Aborted.")
            return 1

    return deployment.runWithProgress(
        f"Destroying container {CONTAINER}",
        deployment.dockerRemoveContainer,
        "error while destroying the requested container.",
        CONTAINER,
    )


def commit_container(tag="latest"):
    image = _resolve_image_from_tag(tag)

    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 2

    return deployment.runWithProgress(
        f"Committing container {CONTAINER} into {image}",
        deployment.dockerCommitContainer,
        "error while committing the requested container.",
        CONTAINER,
        image,
    )


def save_container(imgfile, tag="latest"):
    image = _resolve_image_from_tag(tag)

    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 2

    imgfile = Path(imgfile).expanduser().resolve()

    return deployment.runWithProgress(
        f"Saving container {CONTAINER} to {imgfile}",
        deployment.dockerCommitAndSaveContainer,
        "error while saving the requested container.",
        CONTAINER,
        image,
        str(imgfile),
    )


def checkpoint_container(tag="latest", inventory=DEFAULT_INVENTORY, network=NETWORK, subnet=SUBNET):
    image = _resolve_image_from_tag(tag)

    if not deployment.dockerContainerExists(CONTAINER):
        print(f"Container {CONTAINER} not created.")
        return 2

    rc = deployment.runWithProgress(
        f"Committing container {CONTAINER} into {image}",
        deployment.dockerCommitContainer,
        "error while committing the requested container.",
        CONTAINER,
        image,
    )
    if rc != 0:
        return rc

    rc = destroy_container(force=True)
    if rc != 0:
        return rc

    return create_container(
        inventory=inventory,
        tag=tag,
        network=network,
        subnet=subnet,
    )


def login_registry(registry="ghcr.io"):
    username = input("GitHub username: ").strip()
    if not username:
        print("Username required.")
        return 1

    token = getpass.getpass("GitHub PAT (classic, read:packages): ")
    if not token:
        print("Token required.")
        return 1

    return deployment.runWithProgress(
        f"Logging in to {registry} as {username}",
        deployment.dockerLogin,
        "error while logging in to the registry.",
        registry,
        username,
        token,
    )


def logout_registry(registry="ghcr.io"):
    return deployment.runWithProgress(
        f"Logging out from {registry}",
        deployment.dockerLogout,
        "error while logging out from the registry.",
        registry,
    )


def _bind_command(parser, func, *arg_names):
    parser.set_defaults(func=func, arg_names=arg_names)


def _parse_args():
    parser = argparse.ArgumentParser(
        description=f"Handle the DISCOS development container. {__doc__}",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="show Docker output",
    )

    subparsers = parser.add_subparsers(dest="action", required=True)

    def add_inventory(p):
        p.add_argument(
            "--inventory",
            default=DEFAULT_INVENTORY,
            help=f"inventory to use for IP lookup (default: {DEFAULT_INVENTORY})",
        )

    def add_imgfile(p):
        p.add_argument(
            "imgfile",
            help="image .tar filename",
        )

    def add_tag(p, default=None):
        p.add_argument(
            "--tag",
            default=default,
            help=(
                "image tag to use. "
                "If not provided: latest if available, base otherwise"
            ),
        )

    def add_network(p):
        p.add_argument(
            "--network",
            default=NETWORK,
            help=f"Docker network to use (default: {NETWORK})",
        )
        p.add_argument(
            "--subnet",
            default=SUBNET,
            help=f"Docker subnet to use (default: {SUBNET})",
        )

    p = subparsers.add_parser("build")
    _bind_command(p, build_image)

    p = subparsers.add_parser("remove")
    _bind_command(p, remove_image)

    p = subparsers.add_parser("load")
    add_imgfile(p)
    _bind_command(p, load_image, "imgfile")

    p = subparsers.add_parser("commit")
    add_tag(p)
    _bind_command(p, commit_container, "tag")

    p = subparsers.add_parser("save")
    add_imgfile(p)
    add_tag(p)
    _bind_command(p, save_container, "imgfile", "tag")

    p = subparsers.add_parser("status")
    add_inventory(p)
    _bind_command(p, status_container, "inventory")

    p = subparsers.add_parser("start")
    add_inventory(p)
    _bind_command(p, start_container, "inventory")

    p = subparsers.add_parser("stop")
    _bind_command(p, stop_container)

    p = subparsers.add_parser("restart")
    add_inventory(p)
    _bind_command(p, restart_container, "inventory")

    p = subparsers.add_parser("create")
    add_inventory(p)
    add_network(p)
    add_tag(p)
    _bind_command(p, create_container, "inventory", "tag", "network", "subnet")

    p = subparsers.add_parser("checkpoint")
    add_inventory(p)
    add_network(p)
    add_tag(p, default="latest")
    _bind_command(p, checkpoint_container, "inventory", "tag", "network", "subnet")

    p = subparsers.add_parser("destroy")
    _bind_command(p, destroy_container)

    p = subparsers.add_parser("push")
    add_tag(p, default="latest")
    _bind_command(p, push_image, "tag")

    p = subparsers.add_parser("pull")
    add_tag(p, default="latest")
    _bind_command(p, pull_image, "tag")

    p = subparsers.add_parser("tag")
    p.add_argument("source_tag")
    p.add_argument("target_tag")
    _bind_command(p, tag_image, "source_tag", "target_tag")

    p = subparsers.add_parser("login")
    _bind_command(p, login_registry)

    p = subparsers.add_parser("logout")
    _bind_command(p, logout_registry)

    return parser.parse_args()


def main():
    args = _parse_args()

    if not args.verbose:
        try:
            from subprocess import DEVNULL
        except ImportError:
            DEVNULL = open(os.devnull, "wb")
        deployment.STDOUT = DEVNULL
        deployment.STDERR = DEVNULL
    else:
        deployment.STDOUT = sys.stdout
        deployment.STDERR = sys.stderr

    _ensure_docker_available()

    kwargs = {name: getattr(args, name) for name in args.arg_names}
    return args.func(**kwargs)


if __name__ == "__main__":
    sys.exit(main())
