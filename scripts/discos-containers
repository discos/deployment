#!/usr/bin/env python3
"""Some command line examples:

  $ discos-containers create manager
  $ discos-containers start console storage
  $ discos-containers restart manager
  $ discos-containers status
  $ discos-containers export manager --output ~/exports
  $ discos-containers destroy console
  $ discos-containers list
  $ discos-containers logs manager
  $ discos-containers save manager discos_manager.tar
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

import deployment

IMAGE = 'discos-centos-7.9'
LATEST_IMAGE = IMAGE + ':latest'
PROVISIONED_IMAGE = IMAGE + ':provisioned'
NETWORK = 'discos_net'
SUBNET = '192.168.56.0/24'


def _vagrant_machines():
    return list(deployment._vagrantList())

def _machine_ip(machine, inventory='development'):
    return deployment.getIp(machine, inventory)

def _check_output(cmd, **kwargs):
    return subprocess.check_output(
        cmd,
        stderr=deployment.STDERR,
        **kwargs
    ).decode().strip()

def _docker_available():
    try:
        _check_output(['docker', 'version', '--format', '{{.Server.Version}}'])
        return True
    except Exception:
        return False

def _ensure_docker_available():
    if not _docker_available():
        deployment.error('Docker is not available or the daemon is not reachable!')

def _container_names():
    try:
        out = _check_output(['docker', 'ps', '-a', '--format', '{{.Names}}'])
    except subprocess.CalledProcessError:
        return []
    return [line.strip() for line in out.splitlines() if line.strip()]

def _image_names():
    try:
        out = _check_output(
            ['docker', 'image', 'ls', '--format', '{{.Repository}}:{{.Tag}}']
        )
    except subprocess.CalledProcessError:
        return []
    return [line.strip() for line in out.splitlines() if line.strip()]

def _resolve_create_image(image_selector=None):
    if image_selector == 'latest':
        return LATEST_IMAGE

    if image_selector == 'provisioned':
        if not deployment.dockerImageExists(PROVISIONED_IMAGE):
            print(f'Image {PROVISIONED_IMAGE} not found.')
            return None
        return PROVISIONED_IMAGE

    if deployment.dockerImageExists(PROVISIONED_IMAGE):
        return PROVISIONED_IMAGE

    if deployment.dockerImageExists(LATEST_IMAGE):
        return LATEST_IMAGE

    print(f'Neither {PROVISIONED_IMAGE} nor {LATEST_IMAGE} exists.')
    return None

def containerList():
    return [m for m in _vagrant_machines() if m in _container_names()]

def imageList():
    return _image_names()

def statusImage(image=PROVISIONED_IMAGE):
    if deployment.dockerImageExists(image):
        print(f'Image {image} exists.')
        return 0
    print(f'Image {image} not found.')
    return 1

def buildImage(image=LATEST_IMAGE):
    if deployment.dockerImageExists(image):
        print(f'Image {image} already exists.')
        return 0
    return deployment.runWithProgress(
        f'Building image {image}',
        deployment.dockerBuild,
        'error while building the requested image.',
        image
    )

def removeImage(image=PROVISIONED_IMAGE):
    if not deployment.dockerImageExists(image):
        print(f'Image {image} not found.')
        return 1
    return deployment.runWithProgress(
        f'Removing image {image}',
        deployment._docker,
        'error while removing the requested image.',
        ['image', 'rm', '-f', image]
    )

def saveImage(image=PROVISIONED_IMAGE, outdir='.'):
    if not deployment.dockerImageExists(image):
        print(f'Image {image} not found.')
        return 1

    outdir = Path(outdir).expanduser()
    outdir.mkdir(parents=True, exist_ok=True)
    outfile = outdir / f"{image.replace('/', '_').replace(':', '_')}.tar"

    return deployment.runWithProgress(
        f'Saving image {image} as {outfile}',
        deployment.dockerSaveImage,
        'error while saving the requested image.',
        image,
        str(outfile)
    )

def listImages():
    print('Docker images available: ')
    for image in imageList():
        print(image)
    return 0

def statusProvisionedImage():
    return statusImage()

def statusContainer(container, inventory='development'):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2
    if deployment.dockerContainerRunning(container):
        ip = _machine_ip(container, inventory)
        print(f'Container {container} is running on {ip}.')
    else:
        print(f'Container {container} stopped.')
    return 0

def createContainer(
    container,
    inventory='development',
    image=LATEST_IMAGE,
    network=NETWORK,
    subnet=SUBNET
):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if deployment.dockerContainerExists(container):
        print(f'Container {container} already created.')
        return 2

    ip = _machine_ip(container, inventory)

    rc = deployment.runWithProgress(
        f'Creating network {network}...',
        deployment.dockerEnsureNetwork,
        'error while creating the requested network.',
        network,
        subnet
    )
    if rc != 0:
        return rc

    return deployment.runWithProgress(
        f'Creating container {container}...',
        deployment.dockerEnsureContainer,
        'error while creating the requested container.',
        container,
        ip,
        image,
        network
    )

def startContainer(container, inventory='development'):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2
    if deployment.dockerContainerRunning(container):
        print(f'Container {container} already running.')
        return 0

    ip = _machine_ip(container, inventory)

    return deployment.runWithProgress(
        f'Starting container {container}...',
        deployment.dockerStartContainer,
        'error while starting the requested container.',
        container,
        ip
    )

def stopContainer(container):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2
    if not deployment.dockerContainerRunning(container):
        print(f'Container {container} is not running.')
        return 0

    return deployment.runWithProgress(
        f'Stopping container {container}...',
        deployment.dockerStopContainer,
        'error while stopping the requested container.',
        container
    )

def restartContainer(container, inventory='development'):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2

    ip = _machine_ip(container, inventory)

    return deployment.runWithProgress(
        f'Restarting container {container}...',
        deployment.dockerRestartContainer,
        'error while restarting the requested container.',
        container,
        ip
    )

def destroyContainer(container):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2

    valid = {'yes': True, 'y': True, 'ye': True, 'no': False, 'n': False}
    prompted = 0
    choice = False
    while True:
        if prompted == 3:
            return 0
        prompted += 1
        sys.stdout.write(
            f'Are you sure you want to destroy container {container}? [y/N]: '
        )
        sys.stdout.flush()
        choice = input().lower()
        if choice not in valid and choice != '':
            continue
        choice = False if choice == '' else valid[choice]
        break
    if choice is False:
        return 0

    return deployment.runWithProgress(
        f'Destroying container {container}...',
        deployment.dockerRemoveContainer,
        'error while destroying the requested container.',
        container
    )

def commitContainer(container, image='discos-centos-7.9:provisioned'):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2
    return deployment.runWithProgress(
        f'Committing container {container} to image {image}',
        deployment.dockerCommitContainer,
        'error while committing the requested container.',
        container,
        image
    )

def exportContainer(container, outdir=os.environ.get('HOME')):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2
    if deployment.dockerContainerRunning(container):
        print(f'Container {container} is running. Stop it and try again.')
        return 3

    outdir = Path(outdir).expanduser()
    outdir.mkdir(parents=True, exist_ok=True)
    outfile = outdir / f'discos_{container}.tar'

    return deployment.runWithProgress(
        f'Exporting container {container} as {outfile}...',
        deployment._docker,
        'error while exporting the requested container.',
        ['export', '-o', str(outfile), container]
    )

def logsContainer(container, follow=True, tail='100'):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2

    cmd = ['docker', 'logs', '--tail', str(tail)]
    if follow:
        cmd.append('-f')
    cmd.append(container)
    return subprocess.call(cmd)

def saveContainer(container, outfile, image=PROVISIONED_IMAGE):
    if container not in _vagrant_machines():
        print(f'Container {container} unknown.')
        return 1
    if not deployment.dockerContainerExists(container):
        print(f'Container {container} not created.')
        return 2

    outfile = Path(outfile).expanduser().resolve()

    return deployment.runWithProgress(
        f'Saving container {container} to {outfile}',
        deployment.dockerCommitAndSaveContainer,
        'error while saving the requested container.',
        container,
        image,
        str(outfile)
    )

def _parse_args(machines):
    parser = argparse.ArgumentParser(
        description=(f'Handle DISCOS containers and images. {__doc__}'),
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument(
        'action',
        choices=[
            'status', 'start', 'stop', 'restart', 'create', 'destroy',
            'commit', 'export', 'list', 'build', 'remove', 'save', 'logs',
            'list-images', 'status-image'
        ],
    )
    parser.add_argument(
        'container',
        nargs='?',
        type=str,
        help='desired container',
        choices=machines,
        default=None,
    )
    parser.add_argument(
        'outfile',
        nargs='?',
        help='output filename for save'
    )
    parser.add_argument(
        '--inventory',
        default='development',
        help='inventory to use for IP lookup (default: development)',
    )
    parser.add_argument(
        '--network',
        default=NETWORK,
        help=f'Docker network to use (default: {NETWORK})',
    )
    parser.add_argument(
        '--subnet',
        default=SUBNET,
        help=f'Docker subnet to use (default: {SUBNET})',
    )
    parser.add_argument(
        '--output',
        default=os.environ.get('HOME'),
        help='output directory for export/save operations',
    )
    parser.add_argument(
        '--tail',
        default='100',
        help='number of log lines to show before following (default: 100)',
    )
    parser.add_argument(
        '--no-follow',
        action='store_true',
        help='do not follow logs in real time',
    )
    parser.add_argument(
        '--image',
        choices=['latest', 'provisioned'],
        default=None,
        help='image to use for create: latest or provisioned '
             '(default: provisioned if available, otherwise latest)',
    )
    parser.add_argument(
        '-v', '--verbose',
        action='store_true',
        help='show Docker output',
    )
    return parser.parse_args()


def main():
    machines = _vagrant_machines()
    args = _parse_args(machines)

    if not args.verbose:
        try:
            from subprocess import DEVNULL
        except ImportError:
            DEVNULL = open(os.devnull, 'wb')
        deployment.STDOUT = DEVNULL
        deployment.STDERR = DEVNULL
    else:
        deployment.STDOUT = sys.stdout
        deployment.STDERR = sys.stderr

    _ensure_docker_available()
    image_actions = {'build', 'remove', 'list-images', 'status-image'}
    container_actions = {
        'status', 'start', 'stop', 'restart', 'create',
        'destroy', 'export', 'list', 'logs', 'commit', 'save'
    }

    if args.action in image_actions:
        if args.container:
            print(f"Action '{args.action}' does not accept container arguments.")
            return 2

        if args.action == 'build':
            return buildImage()
        elif args.action == 'remove':
            return removeImage()
        elif args.action == 'list-images':
            return listImages()
        elif args.action == 'status-image':
            return statusProvisionedImage()

    if args.action in container_actions:
        selected = [args.container] if args.container else list(machines)

        if 'storage' in selected and len(selected) > 1:
            selected.insert(0, selected.pop(selected.index('storage')))

        if args.action in ['stop', 'destroy']:
            selected.reverse()

        if args.action == 'list':
            print('Containers available for deployment: ')
            for machine in selected:
                print(machine)
            return 0

        if args.action == 'logs' and len(selected) != 1:
            print('Action logs requires exactly one container.')
            return 2

        if args.action == 'save':
            if len(selected) != 1:
                print('Action save requires exactly one container.')
                return 2
            if not args.outfile:
                print('Action save requires an output filename.')
                return 2
            return saveContainer(selected[0], args.outfile)

        return_code = 0
        for machine in selected:
            if args.action == 'status':
                return_code = statusContainer(machine, inventory=args.inventory) or return_code
            elif args.action == 'start':
                return_code = startContainer(machine, inventory=args.inventory) or return_code
            elif args.action == 'stop':
                return_code = stopContainer(machine) or return_code
            elif args.action == 'restart':
                return_code = restartContainer(machine, inventory=args.inventory) or return_code
            elif args.action == 'create':
                image = _resolve_create_image(args.image)
                if image is None:
                    return 2
                return_code = createContainer(
                    machine,
                    inventory=args.inventory,
                    image=image,
                    network=args.network,
                    subnet=args.subnet,
                ) or return_code
            elif args.action == 'destroy':
                return_code = destroyContainer(machine) or return_code
            elif args.action == 'export':
                return_code = exportContainer(machine, outdir=args.output) or return_code
            elif args.action == 'logs':
                return logsContainer(machine, follow=not args.no_follow, tail=args.tail)
            elif args.action == 'commit':
                return_code = commitContainer(machine) or return_code

        return return_code

    print(f"Unknown action '{args.action}'.")
    return 2


if __name__ == '__main__':
    sys.exit(main())
